<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
    <add key="local" value="./.nuget/" />
    <!-- Browse at https://dev.azure.com/tonerdo/coverlet/_artifacts/feed/coverlet-nightly -->
    <add key="coverlet-nightly" value="https://pkgs.dev.azure.com/tonerdo/coverlet/_packaging/coverlet-nightly/nuget/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget">
      <package pattern="*" />
      <package pattern="coverlet.*" />
      <package pattern="dotnet-reportgenerator-globaltool" />
    </packageSource>
    <packageSource key="local">
      <package pattern="coverlet.*" />
      <package pattern="dotnet-reportgenerator-globaltool" />
    </packageSource>
  </packageSourceMapping>

</configuration>
