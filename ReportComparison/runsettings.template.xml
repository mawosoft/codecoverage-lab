<?xml version="1.0" encoding="utf-8"?>
<!--
  This template is used to generate settings variations for 'dotnet test' and 'dotnet-coverage'.
  For the latter, only the <Configuration> section of the 'Code Coverage' data collector is used.

  Do NOT use relative paths in this template. 'dotnet test' bases them on the location of the
  .runsettings file while 'dotnet-coverage' uses the current working directory.
  Furthermore, the actual settings file derived from this template will be stored in a temporary
  location, different from the location of the template.
-->
<RunSettings>
  <RunConfiguration>
    <SkipDefaultAdapters>true</SkipDefaultAdapters>
  </RunConfiguration>
  <DataCollectionRunSettings>
    <!-- enabled="false" is necessary if multiple data collectors are defined and included via PackageReference. -->
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage" enabled="false">
        <Configuration>
          <IncludeTestAssembly>false</IncludeTestAssembly>
          <SkipAutoProps>false</SkipAutoProps>
          <Include>[CoverageDemo]*</Include>
          <!-- Note: The attribute 'Microsoft.VisualStudio.TestPlatform.TestSDKAutoGeneratedCode' does **not** have an 'Attribute' suffix -->
          <ExcludeByAttribute>GeneratedCodeAttribute,ExcludeFromCodeCoverageAttribute,TestSDKAutoGeneratedCode</ExcludeByAttribute>
          <!-- 'DoesNotReturnAttribute' needs to be explicitly specified. -->
          <DoesNotReturnAttribute>DoesNotReturnAttribute</DoesNotReturnAttribute>
        </Configuration>
      </DataCollector>
      <DataCollector friendlyName="Code Coverage" enabled="false">
        <Configuration>
          <Format>xml</Format>
          <IncludeTestAssembly>false</IncludeTestAssembly>
          <!-- Undocumented enum: None, SameAssembly, AllAssemblies (0, 1, 2). Case-sensitive. Default: SameAssembly.
               AllAssemblies matches coverlet behavior. -->
          <DoesNotReturnAttribute>AllAssemblies</DoesNotReturnAttribute>
          <CodeCoverage>
            <ModulePaths>
              <Include>
                <ModulePath>.*CoverageDemo\.dll$</ModulePath>
              </Include>
            </ModulePaths>
            <Attributes>
              <!-- Only the 'GeneratedCodeAttribute' needs to be explicitly specified. The others are already defaults. -->
              <Exclude>
                <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
                <Attribute>^System\.Diagnostics\.CodeAnalysis\.ExcludeFromCodeCoverageAttribute$</Attribute>
                <Attribute>^Microsoft\.VisualStudio\.TestPlatform\.TestSDKAutoGeneratedCode$</Attribute>
              </Exclude>
            </Attributes>
            <!-- dotnet-coverage and Microsoft.CodeCoverage have different defaults. -->
            <SkipAutoProperties>false</SkipAutoProperties>
            <EnableDynamicNativeInstrumentation>false</EnableDynamicNativeInstrumentation>
            <EnableStaticNativeInstrumentation>false</EnableStaticNativeInstrumentation>
            <EnableDynamicManagedInstrumentation>true</EnableDynamicManagedInstrumentation>
            <EnableStaticManagedInstrumentation>false</EnableStaticManagedInstrumentation>
          </CodeCoverage>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
